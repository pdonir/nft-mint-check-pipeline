# Telegram bot credentials and target chat.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Default topic/thread for outgoing replies in Telegram forum groups.
# Leave empty for normal groups/DMs.
TELEGRAM_MESSAGE_THREAD_ID=
UPCOMING_MINTS_THREAD_ID=

# Optional comma-separated topic/thread allowlist for commands.
# Example: UPCOMING_MINTS_ALLOWED_THREAD_IDS=123,456
UPCOMING_MINTS_ALLOWED_THREAD_IDS=

# Optional result cap for /upcoming and /slug output.
UPCOMING_NOTIFIER_MAX_RESULTS=12

# Optional admin-only full pipeline trigger: /runcheck and /runcheck status.
# Comma-separated Telegram user IDs allowed to run the pipeline.
UPCOMING_NOTIFIER_ADMIN_USER_IDS=
UPCOMING_PIPELINE_COMMAND=python3 scripts/pipeline/nft_wl_check_pipeline.py
UPCOMING_PIPELINE_TIMEOUT=1800
UPCOMING_PIPELINE_LOG_FILE=upcoming_pipeline_manual.log

# Optional admin-only scraper-only trigger: /getlinks (no eligibility check).
# Same admin allowlist as /runcheck (UPCOMING_NOTIFIER_ADMIN_USER_IDS).
UPCOMING_SCRAPER_COMMAND=python3 scripts/scraper/x_list_scraper.py
UPCOMING_SCRAPER_TIMEOUT=600
UPCOMING_SCRAPER_LOG_FILE=scraper_manual.log

# Twitter/X cookies used by the scraper (read by /getlinks and the full pipeline).
# File must contain valid auth_token + ct0 for the lists you want to scrape.
TWITTER_COOKIES_FILE=/path/to/twitter_cookies.json

# Browser-based OpenSea eligibility checker — fallback when the API checker
# (opensea_checker_api_batch.py) fails or times out. Defaults to
# scripts/checker/opensea_checker/opensea_checker_browser_batch.py inside
# this workload. Override only if your browser checker lives in a different
# tree (e.g. a sibling workload). Leave commented to use the default.
# NFT_TRADE_ELIG_FALLBACK=/path/to/opensea_checker_browser_batch.py

# Browser checker dependencies (Playwright + Rabby wallet extension).
# All three are required by opensea_checker_browser.py and
# opensea_checker_browser_batch.py. Shared across workloads under
# <workload-root>/shared/ so they stay in one place.
RABBY_SECRETS_FILE=/path/to/rabby_password.env
RABBY_EXTENSION_DIR=/path/to/rabby_extension
OPENSEA_PROFILE_BASE=/path/to/browser_profiles

# Global service-gate lock — makes /runcheck + /getlinks + /check mutually exclusive.
# Per-command locks live at /tmp/nft_mint_check.lock and /tmp/nft_scraper.lock by default.
NFT_SERVICE_LOCK_FILE=/tmp/nft_service.lock

NFT_CONFIG_PATH=/path/to/nft_config.json
