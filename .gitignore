# Per-workload secrets folder (cookies, browser profiles, passwords)
secrets/

# Sensitive config (real values — use .example.json templates)
wallets.json
list_nft.json
twitter_cookies.json
*.cookies.json
.env
*.env
.*.env

# Generated data (changes every run)
scraped_links.json
upcoming_mints.json
last_elig_report.txt
*.bak
*.log
*_state.json
*_skipped.log
opensea_api_errors.log

# Python
__pycache__/
*.pyc
*.pyo

# Debug / backup scripts
debug_scraper*.py
mint_pipeline_backup.py
run_pipeline_backup.sh

# Local-only OpenSea detector/guard scripts
opensea_*detector*.py
opensea_*guard_wrapper.py

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Local-only archive (pre-restructure backups — kept on disk for rollback,
# not for public repo since they reference old paths/wallet names)
archive/
# Backup files with extra suffixes (e.g. foo.json.bak.20260101_120000)
*.bak.*
*.bak
*~

# systemd user service stderr/stdout noise
*.stderr
*.stdout

# Project runtime folders
logs/
state/
config/*.env
config/wallets.json
config/list_nft.json
# Whitelist example templates (must stay tracked so README "cp example" instructions work)
!config/wallets.example.json
!config/list_nft.example.json
!config/upcoming_mints_notifier.env.example
